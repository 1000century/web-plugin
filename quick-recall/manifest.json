{
  "manifest_version": 3,
  "name": "ADHD Quiz Helper",
  "version": "1.6",
  "description": "드래그한 텍스트를 즉시 퀴즈로 변환. 공부하면서 읽은 내용을 클릭 한 번으로 AI 퀴즈 생성.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://aiplatform.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "action": {
    "default_title": "ADHD Quiz Helper",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
